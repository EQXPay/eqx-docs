  "info": {
    "title": "EQX Settlement API",
    "description": "EQX v2.5 staging API for admin, liquidity-provider, and integrator operations.",
    "version": "2.5.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      },
      "Idempotency-Key": {
        "type": "apiKey",
        "in": "header",
        "name": "Idempotency-Key",
        "description": "Required on critical write endpoints."
      }
    },
    "schemas": {
      "CreateQuoteDto": {
        "type": "object",
        "properties": {
          "market": {
            "type": "string",
            "description": "Market code for the offramp corridor (e.g. KE, NG)",
            "example": "KE"
          },
          "source_asset": {
            "type": "string",
            "description": "Source crypto asset symbol (e.g. USDC, USDT)",
            "example": "USDC"
          },
          "source_amount": {
            "type": "string",
            "description": "Amount of source asset to convert (decimal string)",
            "example": "100.00"
          },
          "payout_method": {
            "type": "string",
            "enum": [
              "MOBILE_MONEY",
              "BANK_TRANSFER"
            ],
            "description": "Payout method",
            "example": "MOBILE_MONEY"
          },
          "beneficiary_id": {
            "type": "string",
            "description": "Beneficiary ID to receive the payout",
